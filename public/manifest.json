{
  "name": "TaskPilot",
  "short_name": "TaskPilot",
  "description": "Capture tasks from WhatsApp, Gmail and anywhere.",
  "display": "standalone",
  "start_url": "/",
  "scope": "/",
  "background_color": "#ffffff",
  "theme_color": "#171717",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/Home-mobile.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/Home-desktop.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "link",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "application/pdf", "audio/*"]
        }
      ]
    }
  }
}